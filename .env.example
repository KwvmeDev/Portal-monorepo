# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/portal_dev

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── AI Moderation (Anthropic) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Email (Gmail + App Password) ────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8081

# ─── Mobile (Expo) ───────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
